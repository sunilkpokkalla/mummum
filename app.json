{
  "expo": {
    "name": "Mummum: Baby Tracker",
    "slug": "mummum",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/MUMMUM_FINAL.png",
    "scheme": "mummum",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/MUMMUM_FINAL.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ambright.mummum",
      "useFrameworks": "static",
      "buildNumber": "2",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Mummum needs access to your photos to save milestone memories and profile pictures for your baby.",
        "NSPhotoLibraryAddUsageDescription": "Mummum needs permission to save daily clinical reports to your photo gallery.",
        "NSCameraUsageDescription": "Mummum needs camera access to capture new milestone photos of your baby.",
        "NSMicrophoneUsageDescription": "Mummum needs microphone access for video milestones."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/MUMMUM_FINAL.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ambright.mummum",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/MUMMUM_FINAL.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "16.0",
            "enableUserScriptSandboxing": false,
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBSharedUtils",
              "RNFBUtilsModule"
            ]
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you save baby milestones and clinical memories.",
          "cameraPermission": "The app uses your camera to capture clinical snapshots and milestones for your baby's medical history."
        }
      ],
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}